SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_publishable_key_here

# JWT anon (eyJ...) — trigger pg_net y notifyResendEmail en el formulario
# Dashboard → Project Settings → API → anon / legacy
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Token personal para scripts/setup_resend_email.py (aplica trigger + deploy)
# https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_...
# SUPABASE_PROJECT_REF=your_project_ref

# Secretos de Resend (los sube setup_resend_email.py a la Edge Function)
# RESEND_API_KEY=re_...
# NOTIFY_EMAIL=burguardreams@gmail.com
# RESEND_FROM="Burguar Dreams <onboarding@resend.dev>"
