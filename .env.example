SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_publishable_key_here

# Opcional: clave anon legacy (eyJ...) para resend-email si Verify JWT sigue activado
# Dashboard → Project Settings → API → anon / legacy
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Opcional: desactivar Verify JWT en resend-email sin tocar el Dashboard
# SUPABASE_ACCESS_TOKEN=your_personal_access_token
# SUPABASE_PROJECT_REF=your_project_ref
